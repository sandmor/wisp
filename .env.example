DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wisp"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Admin access
ADMIN_EMAIL=""

# Cleanup secret for secure deletion of files after TTL expires
CLEANUP_SECRET="changeme"

# S3-compatible storage
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET_NAME="wisp"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# Upload limits
MAX_FILE_SIZE_MB="500"
TTL_OPTIONS_HOURS="1,6,24,72,168"